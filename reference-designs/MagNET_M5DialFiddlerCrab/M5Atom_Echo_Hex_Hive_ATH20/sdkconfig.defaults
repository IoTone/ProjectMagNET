# M5Atom Echo (ESP32-PICO-D4) + M5 Unit Hex (37× SK6812)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
CONFIG_FREERTOS_HZ=1000
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Classic ESP32 has no USB-serial-JTAG — use UART0 via CP2104 bridge.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# BLE — NimBLE only, classic BT off
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
# Only one provisioning client at a time — saves a few KB per slot on
# this DRAM-tight classic ESP32. Phone/laptop disconnects before next
# device, so 1 is enough for the provisioning flow.
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_BT_BLUEDROID_ENABLED=n
CONFIG_BT_CTRL_MODE_EFF_BLE_ONLY=y

# WiFi RAM trim — default static RX buffer pool is 10; 4 is plenty for the
# UC2 polling pattern (one client, low RPS) and saves ~10 KB of DRAM so the
# BT/WiFi coexistence arbiter can find its contiguous block at esp_wifi_start.
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4

# Save RAM
CONFIG_LWIP_IPV6=n

# HTTP server (UC2 env sensor API) — same shape as lighting/boombox.
CONFIG_LWIP_MAX_SOCKETS=16
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
