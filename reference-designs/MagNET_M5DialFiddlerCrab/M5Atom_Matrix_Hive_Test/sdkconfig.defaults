# M5Atom Matrix — ESP32-PICO-D4 (classic dual-core Tensilica)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
CONFIG_FREERTOS_HZ=1000
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Classic ESP32 has no USB-serial-JTAG — use UART0 via CP2104 bridge.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_UART_BAUDRATE=115200

# Partition table (extra space for BLE + WiFi + mbedTLS + mDNS)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# BLE — NimBLE only, classic BT off to save RAM.
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=3
CONFIG_BT_CONTROLLER_ONLY=n
CONFIG_BT_BLUEDROID_ENABLED=n

# Classic ESP32 BLE controller mode: BLE-only, no classic BT.
CONFIG_BT_CTRL_MODE_EFF_BLE_ONLY=y

# Save RAM
CONFIG_LWIP_IPV6=n
