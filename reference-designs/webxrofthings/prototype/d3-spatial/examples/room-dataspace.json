{
  "version": "1",
  "name": "lab-room-alpha",
  "scaleTag": "room",
  "owner": "labadmin@example.com",
  "acousticEnvironment": "indoor",
  "marks": [
    {
      "id": "device-tree",
      "type": "tree",
      "title": "Device Topology",
      "subtitle": "All connected IoT devices",
      "data": {
        "source": "inline",
        "hierarchy": {
          "name": "gateway",
          "children": [
            {
              "name": "sensors",
              "children": [
                { "name": "temp-living", "value": 22 },
                { "name": "temp-bedroom", "value": 19 },
                { "name": "humidity-living", "value": 45 },
                { "name": "motion-hallway", "value": 1 }
              ]
            },
            {
              "name": "actuators",
              "children": [
                { "name": "light-ceiling", "value": 80 },
                { "name": "light-desk", "value": 60 },
                { "name": "thermostat", "value": 21 }
              ]
            },
            {
              "name": "media",
              "children": [
                { "name": "speaker-left", "value": 40 },
                { "name": "speaker-right", "value": 40 }
              ]
            }
          ]
        }
      },
      "config": { "form": "radial" },
      "drillable": true,
      "hoverable": true
    },
    {
      "id": "temp-history",
      "type": "bar",
      "title": "Temperature (last 6h)",
      "subtitle": "Living room sensor",
      "data": {
        "source": "inline",
        "series": [
          { "t": 0,  "v": 20.1 },
          { "t": 1,  "v": 20.4 },
          { "t": 2,  "v": 21.0 },
          { "t": 3,  "v": 21.8 },
          { "t": 4,  "v": 22.3 },
          { "t": 5,  "v": 22.0 }
        ]
      },
      "hoverable": true
    },
    {
      "id": "network-graph",
      "type": "force",
      "title": "Network Map",
      "subtitle": "Device connectivity",
      "data": {
        "source": "inline",
        "graph": {
          "nodes": [
            { "id": "gateway",       "group": 0 },
            { "id": "ap-living",     "group": 1 },
            { "id": "ap-bedroom",    "group": 1 },
            { "id": "temp-living",   "group": 2 },
            { "id": "temp-bedroom",  "group": 2 },
            { "id": "light-ceiling", "group": 3 },
            { "id": "light-desk",    "group": 3 },
            { "id": "thermostat",    "group": 3 },
            { "id": "speaker-left",  "group": 4 },
            { "id": "speaker-right", "group": 4 }
          ],
          "links": [
            { "source": "gateway",    "target": "ap-living",     "value": 10 },
            { "source": "gateway",    "target": "ap-bedroom",    "value": 10 },
            { "source": "ap-living",  "target": "temp-living",   "value": 5 },
            { "source": "ap-living",  "target": "light-ceiling", "value": 5 },
            { "source": "ap-living",  "target": "light-desk",    "value": 5 },
            { "source": "ap-living",  "target": "thermostat",    "value": 5 },
            { "source": "ap-living",  "target": "speaker-left",  "value": 3 },
            { "source": "ap-living",  "target": "speaker-right", "value": 3 },
            { "source": "ap-bedroom", "target": "temp-bedroom",  "value": 5 }
          ]
        }
      },
      "hoverable": true,
      "draggable": true
    }
  ]
}
