      "config": {
        "clusters": 5,
        "leavesPerCluster": 5,
        "size": 0.42,
        "radius": 0.01725,
        "position": { "x": 0, "y": 0.80, "z": 0.02 }
      },
      "hoverable": true
    },
    {
      "id": "exhibit-owls",
