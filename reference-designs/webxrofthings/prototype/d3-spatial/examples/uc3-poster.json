  "acousticEnvironment": "indoor",
  "_comment": "UC3 'XRt Exhibit' — generative-art / data-art exhibits authored as manifest marks. The voronoi-stippling mark is a flat panel (grid-placeable); moon-phases-arc is self-positioned and wraps a 300° arc around the user from front-centre to behind. Originally a conference-poster placeholder (see webxrofthings/PROPOSAL.md §UC3); rebranded to a curated mini-exhibit so DEMO03 has real generative content while a full poster-session toolkit is built out.",
  "marks": [
    {
      "id": "exhibit-stippling",
      "type": "voronoi-stippling",
      "title": "Voronoi Stippling",
      "subtitle": "after Mike Bostock · live iteration",
      "data": {
        "source": "url",
        "url": "/spatial/_DSC7796.jpeg",
        "shape": "video"
      },
      "config": {
        "samples": 6000,
        "width": 0.84,
        "height": 0.64,
        "stepsPerFrame": 1,
        "maxSteps": 150,
        "dotSize": 1.9,
        "invert": true,
        "maxGridDim": 256,
        "prism": true,
        "attribution": "Attribution: Vincent Foster (Sony A6)."
      },
      "hoverable": false
    },
    {
      "id": "exhibit-moons",
      "type": "moon-phases-arc",
      "title": "Phases of the Moon",
      "subtitle": "one synodic month · 300° arc",
      "data": {
        "source": "inline"
      },
      "config": {
        "count": 29,
        "arcDegrees": 300,
        "radius": 2.6,
        "moonSize": 0.30,
        "height": 1.6
      },
      "hoverable": false
    },
    {
      "id": "exhibit-force-tree",
      "type": "force-tree-3d",
