{
  "version": "1",
  "name": "uc4-airplane",
  "scaleTag": "vehicle",
  "owner": "dkords@gmail.com",
  "acousticEnvironment": "vehicle",

  "udm_version": "1.0",
  "udm_doc_version": "0.1.0",

  "_comment": "UC4 airplane dataspace. P5a wires the IMU sim + airplane viz; P5b adds spatial-audio music; P5c adds HLS streaming video plane; P5d adds the SOG spatial-photo gallery (3 photos).",

  "udm_devices": [
    {
      "udm_key":   "airplane-imu-001",
      "udm_uuid":  "urn:device:imu:airplane-001",
      "_comment":  "Simulated airplane IMU. Backed by mock-join-server for the demo; the real-device swap is a single URL change in the manifest below.",
      "udm_model_name":   "Airplane IMU (sim)",
      "udm_vendor":       "MagNET (sim)",
      "udm_mktg_name":    "Airplane IMU",
      "udm_type":         "motion-sensor",
      "udm_class":        ["motion-sensor", "imu", "vehicle"],
      "udm_capabilities": ["orientation-euler", "angular-velocity", "linear-acceleration", "json-http"],
      "udm_sensors":      ["accelerometer", "gyroscope"],
      "udm_services_link": ["imu-snapshot"],
      "udm_tags":         ["vehicle", "simulated"],
      "udm_spatial_anchor_x": { "x": 0.0, "y": 1.2, "z": -0.6 }
    },
    {
      "udm_key":   "cabin-boombox-001",
      "udm_uuid":  "urn:device:spatial-audio:boombox-001",
      "_comment":  "Procedural music boombox. P5b stub — plays an 8-second I-V-vi-IV loop generated in code (no audio asset to ship). Spatialised via THREE.PositionalAudio on the camera's AudioListener.",
      "udm_model_name":   "Cabin boombox (procedural)",
      "udm_vendor":       "MagNET (sim)",
      "udm_mktg_name":    "In-cabin music player",
      "udm_type":         "actuator",
      "udm_class":        ["actuator", "audio", "spatial"],
      "udm_capabilities": ["procedural-music", "positional-audio", "loop"],
      "udm_services_link": [],
      "udm_tags":         ["vehicle", "audio", "simulated"],
      "udm_spatial_anchor_x": { "x": -0.45, "y": 0.95, "z": -0.4 }
    },
    {
      "udm_key":   "cabin-display-001",
      "udm_uuid":  "urn:device:hls-display:cabin-001",
      "_comment":  "In-cabin HLS streaming display. P5c stub: plays the Mux test stream (Big Buck Bunny). Treat the stream URL as an external resource — replace with a real cabin-IFE backend later by editing the manifest's serviceRef URL.",
      "udm_model_name":   "Cabin Display (HLS)",
      "udm_vendor":       "MagNET (sim)",
      "udm_mktg_name":    "Cabin Display",
      "udm_type":         "display",
      "udm_class":        ["display", "video", "streaming"],
      "udm_capabilities": ["hls", "h264", "multi-bitrate"],
      "udm_services_link": ["cabin-stream"],
      "udm_tags":         ["vehicle", "video", "external-url"],
      "udm_spatial_anchor_x": { "x": 0.0, "y": 1.4, "z": -1.2 }
    },
    {
      "udm_key":   "cabin-spatial-gallery-001",
      "udm_uuid":  "urn:device:spatial-photo-gallery:cabin-001",
      "_comment":  "Spatial-photo gallery: a Gaussian-splat viewer that cycles through three .sog scenes (sourced from ../../ml-sharp/samples and copied into public/spatial/). Treat as a 'frame' device: the manifest configures which photos it cycles through.",
      "udm_model_name":   "Spatial Photo Frame (3D Gaussian)",
      "udm_vendor":       "MagNET (sim)",
      "udm_mktg_name":    "Cabin Spatial Gallery",
      "udm_type":         "display",
      "udm_class":        ["display", "gaussian-splat", "spatial-photo"],
      "udm_capabilities": ["sog-format", "ply-format", "auto-advance", "manual-navigation"],
      "udm_services_link": [],
      "udm_tags":         ["vehicle", "photo", "spatial"],
      "udm_spatial_anchor_x": { "x": 0.7, "y": 1.2, "z": -0.8 }
    }
  ],

  "usm_services": [
    {
      "usm_key": "imu-snapshot",
      "usm_uuid": "urn:service:imu-snapshot:airplane-001",
      "usm_service_name": "Airplane IMU snapshot",
      "usm_type": "sensor",
      "usm_class": ["sensor", "motion", "snapshot"],
      "usm_service_endpoint": {
        "GET": { "url": "/api/v1/sensor/imu", "content-type": "application/json" }
      },
      "usm_polling_x": { "interval_seconds": 0.2 },
      "characteristics": [
        { "usm_characteristic_id": "orientation",      "usm_characteristic_format": "{roll_rad,pitch_rad,yaw_rad}",
          "usm_characteristic_constraints": { "unit": "radians" } },
        { "usm_characteristic_id": "angular_velocity", "usm_characteristic_format": "{x,y,z}",
          "usm_characteristic_constraints": { "unit": "rad/s" } },
        { "usm_characteristic_id": "acceleration",     "usm_characteristic_format": "{x,y,z}",
          "usm_characteristic_constraints": { "unit": "m/s^2" } }
      ],
      "usm_tags": ["live", "motion", "simulated"]
    },
    {
      "usm_key": "cabin-stream",
      "usm_uuid": "urn:service:hls-stream:cabin-001",
      "usm_service_name": "Cabin display HLS stream",
      "usm_type": "video",
      "usm_class": ["video", "hls", "external"],
      "usm_service_endpoint": {
        "GET": {
          "url": "https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8",
          "content-type": "application/vnd.apple.mpegurl"
        }
      },
      "usm_capabilities": { "resolutions": ["960x540", "1280x720"], "framerate_hz": [24] },
      "characteristics": [
        { "usm_characteristic_id": "playlist", "usm_characteristic_format": "m3u8" }
      ],
      "usm_tags": ["live", "external-url", "demo-stream"]
    }
  ],

  "marks": [
    {
      "id": "airplane-imu",
      "type": "imu",
      "title": "Airplane attitude",
      "subtitle": "live IMU · simulated",
      "data": {
        "source": "url",
        "url": "/api/v1/sensor/imu",
        "shape": "imu",
        "refreshInterval": 0.2
      },
      "config": {
        "size": 0.12,
        "color": 16769280,
        "smooth": true
      },
      "deviceRef": "airplane-imu-001",
      "serviceRef": "imu-snapshot",
      "hoverable": true
    },
    {
      "id": "cabin-boombox",
      "type": "spatial-audio",
      "title": "Cabin boombox",
      "subtitle": "procedural music · spatialised",
      "data": { "source": "inline" },
      "config": {
        "size": 0.08,
        "refDistance": 0.6,
        "gain": 0.6,
        "autoplay": true
      },
      "deviceRef": "cabin-boombox-001",
      "hoverable": true
    },
    {
      "id": "cabin-display",
      "type": "video",
      "title": "Cabin display",
      "subtitle": "HLS stream · 16:9",
      "data": {
        "source": "url",
        "url": "https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8",
        "shape": "video"
      },
      "config": {
        "type": "hls",
        "width": 0.6,
        "aspectRatio": 1.7777,
        "autoplay": true,
        "muted": true
      },
      "deviceRef": "cabin-display-001",
      "serviceRef": "cabin-stream",
      "hoverable": true
    },
    {
      "id": "cabin-spatial-gallery",
      "type": "splat-gallery",
      "title": "Spatial photo gallery",
      "subtitle": "3D Gaussian splats · ArrowL / ArrowR to navigate",
      "data": { "source": "inline" },
      "config": {
        "photos": [
          { "url": "/spatial/medaka_20260112_221836000_iOS.compressed.ply", "title": "Medaka" },
          { "url": "/spatial/_DSC1624.compressed.ply",                     "title": "DSC 1624" },
          { "url": "/spatial/_DSC8994.compressed.ply",                     "title": "DSC 8994" }
        ],
        "autoAdvanceMs": 15000,
        "splatY": 0,
        "splatAlphaRemovalThreshold": 5
      },
      "deviceRef": "cabin-spatial-gallery-001",
      "hoverable": true
    }
  ]
}
