{
  "name": "d3-spatial-prototype",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Milestone 0 scaffold for d3-spatial — WebXR + three.js + three-mesh-ui + troika-three-text",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "smoke:baseline": "node scripts/smoke-baseline.mjs",
    "smoke:diff": "node scripts/smoke-diff.mjs",
    "server": "npx tsx server/mock-join-server.ts",
    "camera-proxy": "npx tsx server/camera-proxy.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-sankey": "^0.12.5",
    "d3-array": "^3.2.4",
    "d3-force-3d": "^3.0.6",
    "d3-hierarchy": "^3.1.2",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "hls.js": "^1.6.16",
    "omnitone": "^1.3.0",
    "three": "^0.161.0",
    "three-mesh-ui": "^6.5.4",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.6",
    "@types/d3-time": "^3.0.3",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.161.2",
    "@vitest/coverage-v8": "^2.1.9",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^2.1.9"
  }
}
